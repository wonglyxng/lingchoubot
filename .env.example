# ===== 服务器配置 =====
# 监听地址，0.0.0.0 表示接受所有网络接口的连接
SERVER_HOST=0.0.0.0
# HTTP 服务端口
SERVER_PORT=8080
# Docker Compose 暴露到宿主机的 API 端口；若 8080 被占用可改成 18080 等其他端口
API_HOST_PORT=8080
# 前端在浏览器中访问 API 的地址；修改 API_HOST_PORT 时这里也要同步修改
NEXT_PUBLIC_API_URL=http://localhost:8080
# Docker Compose 暴露到宿主机的前端端口；若 3000 被占用可改成 13000 等其他端口
FRONTEND_HOST_PORT=3000

# ===== 数据库配置（PostgreSQL）=====
# 数据库主机地址（Docker Compose 内使用服务名 postgres）
DB_HOST=postgres
# 数据库端口
DB_PORT=5432
# 数据库用户名
DB_USER=lingchou
# 数据库密码
DB_PASSWORD=lingchou
# 数据库名称
DB_NAME=lingchou
# SSL 模式（disable / require / verify-full）
DB_SSLMODE=disable

# ===== MinIO 对象存储配置 =====
# MinIO 服务端点（Docker Compose 内使用服务名 minio）
MINIO_ENDPOINT=minio:9000
# MinIO 访问密钥
MINIO_ACCESS_KEY=lingchou
# MinIO 秘密密钥
MINIO_SECRET_KEY=lingchou_minio_dev
# 工件存储桶名称
MINIO_BUCKET=lingchou-artifacts
# 是否启用 SSL 连接
MINIO_USE_SSL=false

# ===== API 认证 =====
# API 访问密钥（留空则跳过认证，生产环境必须设置）
API_KEY=

# ===== LLM 大语言模型配置 =====
# 是否启用真实 LLM Agent（false 时使用 Mock Agent）
LLM_ENABLED=false
# LLM 调用失败时是否自动降级到 Mock Runner（true = 降级，false = 直接失败）
LLM_FALLBACK_ENABLED=true
# LLM API 基础 URL（兼容 OpenAI / DeepSeek / Ollama 等）
LLM_BASE_URL=https://api.openai.com/v1
# LLM API 密钥
LLM_API_KEY=
# 使用的模型名称
LLM_MODEL=gpt-4o-mini

# ----- 按 Provider 维护连接信息（用于 Agent 级 provider/model 覆盖）-----
# 未显式填写时将使用各 Provider 默认 Base URL。
# 如果某 Provider 的 Base URL 与 LLM_BASE_URL 相同，且其 API_KEY 留空，则自动继承 LLM_API_KEY。
# OpenAI
#LLM_OPENAI_BASE_URL=https://api.openai.com/v1
#LLM_OPENAI_API_KEY=
# DeepSeek
#LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#LLM_DEEPSEEK_API_KEY=
# Qwen / DashScope
#LLM_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#LLM_QWEN_API_KEY=
# Moonshot
#LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
#LLM_MOONSHOT_API_KEY=
# Zhipu
#LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#LLM_ZHIPU_API_KEY=
# SiliconFlow
#LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
#LLM_SILICONFLOW_API_KEY=
# OpenRouter
#LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#LLM_OPENROUTER_API_KEY=
# Ollama
#LLM_OLLAMA_BASE_URL=http://localhost:11434/v1
#LLM_OLLAMA_API_KEY=

# ----- 按角色覆盖 LLM 配置（可选，留空则回退到上方全局配置）-----
# PM（项目经理）
#LLM_PM_BASE_URL=
#LLM_PM_API_KEY=
#LLM_PM_MODEL=
# Supervisor（主管）
#LLM_SUPERVISOR_BASE_URL=
#LLM_SUPERVISOR_API_KEY=
#LLM_SUPERVISOR_MODEL=
# Worker（执行者，包含 backend/frontend/qa 专长）
#LLM_WORKER_BASE_URL=
#LLM_WORKER_API_KEY=
#LLM_WORKER_MODEL=
# Reviewer（评审员）
#LLM_REVIEWER_BASE_URL=
#LLM_REVIEWER_API_KEY=
#LLM_REVIEWER_MODEL=

# ===== Temporal 工作流引擎配置 =====
# 是否启用 Temporal 编排（false 时使用本地 goroutine 编排）
TEMPORAL_ENABLED=false
# Temporal gRPC 服务地址
TEMPORAL_HOST_PORT=localhost:7233
# Temporal 命名空间
TEMPORAL_NAMESPACE=default
# Temporal 任务队列名称
TEMPORAL_TASK_QUEUE=lingchou-orchestrator
# 是否在 API 进程内嵌 Worker（true=开发模式内嵌，false=独立 worker 进程）
TEMPORAL_WORKER_EMBEDDED=true
